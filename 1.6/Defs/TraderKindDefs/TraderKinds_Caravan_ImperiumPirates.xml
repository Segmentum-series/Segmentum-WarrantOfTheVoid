<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--======================================================================================-->

  <TraderKindDef>
    <defName>Seg_WOTV_Caravan_ImperiumPirates</defName>
    <label>Imperium pirate trader</label>
    <requestable>false</requestable>
    <category>Slaver</category>
    <commonalityMultFromPopulationIntent>
      <points>
        <li>(0.2, 0)</li>
        <li>(1,   1)</li>
        <li>(2,   3)</li>
      </points>
    </commonalityMultFromPopulationIntent>
    <stockGenerators>

      <!-- Resources -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>750~1200</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MedicineIndustrial</thingDef>
        <countRange>2~5</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gold</thingDef>
        <countRange>40~80</countRange>
      </li>
      
      <!-- Drugs -->
      <li Class="StockGenerator_Category">
        <categoryDef>Drugs</categoryDef>
        <thingDefCountRange>2~4</thingDefCountRange>
        <totalPriceRange>600~1000</totalPriceRange>
      </li>
      
      <!-- Techprints -->
      <!-- none -->
      
      <!-- Books -->
      <!-- none -->
      
      <!-- Weapons -->
      <li Class="StockGenerator_Tag">
        <tradeTag>MortarShell</tradeTag>
        <thingDefCountRange>-1~2</thingDefCountRange>
        <countRange>1~10</countRange>
        <excludedThingDefs>
          <li MayRequire="Ludeon.RimWorld.Anomaly">Shell_Deadlife</li>
        </excludedThingDefs>
      </li>
      
      <!-- Apparel -->
      <!-- none -->
      
      <!-- Implants -->
      <!-- none -->
      
      <!-- Buildings -->
      <!-- none -->
      
      <!-- Exotic -->
      <!-- none -->

      <!-- Genepacks -->
      <li MayRequire="Ludeon.RimWorld.Biotech" Class="StockGenerator_SingleDef">
        <thingDef>Genepack</thingDef>
        <countRange>1~1</countRange>
      </li>
      
      <!-- Slaves -->
      <li Class="StockGenerator_Slaves">
        <countRange>4~8</countRange>
      </li>
      
      <!-- Animals -->
      <li Class="StockGenerator_Animals">
        <tradeTagsSell>
          <li>AnimalFighter</li>
        </tradeTagsSell>
        <tradeTagsBuy>
          <li>AnimalUncommon</li>
          <li>AnimalExotic</li>
        </tradeTagsBuy>
        <kindCountRange>1~2</kindCountRange>
        <countRange>1~3</countRange>
      </li>

      <!-- Pack turret apparel -->
      <li MayRequire="Ludeon.RimWorld.Anomaly" Class="StockGenerator_SingleDef">
        <thingDef>Apparel_PackTurret</thingDef>
        <countRange>-1~2</countRange> <!-- 50% chance for 1~2 -->
      </li>

      <!-- Segmentum gear -->
      <li MayRequire="Ludeon.RimWorld.Anomaly" Class="StockGenerator_SingleDef">
        <thingDef>Seg_Gun_MarsLasgun</thingDef>
        <countRange>-1~2</countRange>
      </li>
      <li Class="StockGenerator_Tag">
        <tradeTag>Seg_FlakArmour</tradeTag>
        <thingDefCountRange>-1~2</thingDefCountRange>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Seg_WOTV_Gun_LasLock</thingDef>
        <countRange>-1~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Seg_WOTV_Gun_StubRevolver</thingDef>
        <countRange>-1~2</countRange>
      </li>
      <li MayRequire="Ludeon.RimWorld.Odyssey" Class="StockGenerator_SingleDef">
        <thingDef>Seg_WOTV_MiningLaser</thingDef>
        <countRange>-1~2</countRange>
      </li>
      <li MayRequire="REDACTED.Segmentum.ChildrenOfTheOmnissiah" Class="StockGenerator_Tag">
        <tradeTag>Seg_COTO_CrudeAugmetics</tradeTag>
        <thingDefCountRange>-1~4</thingDefCountRange>
        <countRange>1</countRange>
      </li>
      <li MayRequire="REDACTED.Segmentum.ChildrenOfTheOmnissiah" Class="StockGenerator_Tag">
        <tradeTag>Seg_COTO_StandardAugmetics</tradeTag>
        <thingDefCountRange>-1~2</thingDefCountRange>
        <countRange>1</countRange>
      </li>
      
      <!-- Buying -->
      <li Class="StockGenerator_BuyExpensiveSimple" />
      <li Class="StockGenerator_BuyTradeTag"><tag>Art</tag></li>
      <li Class="StockGenerator_BuyTradeTag"><tag>MusicalInstrument</tag></li>
      <li Class="StockGenerator_BuyTradeTag"><tag>Seg_WOTV_BasicWeapons</tag></li>
      <li Class="StockGenerator_BuyTradeTag"><tag>Seg_WOTV_BasicWeapons</tag></li>
      <li Class="StockGenerator_BuyTradeTag"><tag>Seg_WOTV_AdvancedWeapons</tag></li>
      
    </stockGenerators>
  </TraderKindDef>

  <!--======================================================================================-->

</Defs>
