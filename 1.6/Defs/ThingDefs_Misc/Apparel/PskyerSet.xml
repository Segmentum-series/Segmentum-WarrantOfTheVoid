<Defs>

	<!-- Psyker Hood -->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_PsykerHood</defName>
		<label>Psyker Hood</label>
		<description>A hood worn by psykers to contain their psychic powers.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<!-- <shaderType>Cutout</shaderType> -->
			<texPath>Things/Apparel/PsykerHood/Seg_WOTV_PsykerHood</texPath>
			<!-- <drawOffset>(0,0,0.10)</drawOffset> -->
		</graphicData>

		<equippedStatOffsets>
			<PsychicSensitivity>1</PsychicSensitivity>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
			<ArmorRating_Heat>0.55</ArmorRating_Heat>
			<Insulation_Cold>1.1</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>10</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Eyes</li>
				<li>Mouth</li>
				<li>Neck</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/PsykerHood/Seg_WOTV_PsykerHood</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>ComplexClothing</li>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
