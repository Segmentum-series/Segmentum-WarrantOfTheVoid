<Defs>
<!--Breaking change needed this comment is so the file is now different-->
	<ThingDef Abstract="true" Name="Seg_WOTV_ClothingBase" ParentName="ArmorMachineableBase">
		<thingClass>Apparel</thingClass>
		<graphicData>
			<drawSize>1.0</drawSize>
		</graphicData>
		<thingCategories>
			<li>Apparel</li>
		</thingCategories>
		<tradeTags>
			<li>Seg_WOTV_Armor</li>
		</tradeTags>
		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<!--<tags></tags>-->
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
		</apparel>
		
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
			<recipeUsers Inherit="False">
				<li>ElectricTailoringBench</li>
				<li>HandTailoringBench</li>
			</recipeUsers>
		</recipeMaker>
	</ThingDef>

	<ApparelLayerDef>
		<defName>Seg_WOTV_Mask</defName>
		<label>Mask</label>
		<drawOrder>500</drawOrder>
	</ApparelLayerDef>

	<!-- Utility Mask -->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_UtilityMask</defName>
		<label>UtilityMask</label>
		<description>Utility Mask, Bitch.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/UtilityMask/Seg_WOTV_UtilityMask</texPath>
			<!-- <drawOffset>(0,0,0.10)</drawOffset> -->
		</graphicData>

		<equippedStatOffsets>
			<WorkSpeedGlobal>.10</WorkSpeedGlobal>
			<ConstructionSpeed>.25</ConstructionSpeed>
			<ConstructSuccessChance>.20</ConstructSuccessChance>
			<ToxicEnvironmentResistance>.30</ToxicEnvironmentResistance>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
			<ArmorRating_Heat>0.55</ArmorRating_Heat>
			<Insulation_Cold>1.1</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>10</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Eyes</li>
				<li>Mouth</li>
				<li>Neck</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/UtilityMask/Seg_WOTV_UtilityMask</li>
			</wornGraphicPaths>
		</apparel>
		
		<recipeMaker>
			<researchPrerequisites>
				<li>ComplexClothing</li>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
