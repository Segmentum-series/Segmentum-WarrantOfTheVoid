	<!--Utility Jumpsuit-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_ApparelUtilityJumpsuit</defName>
		<label>utility jumpsuit</label>
		<description>This basic jumpsuit is made of cheap but resilient fabric, similar to those worn by the masses of lower-rank labourers and crewmen on a Rogue Trader's voidship.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/UtilityJumpsuit/Seg_WOTV_UtilityJumpsuit</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>2.2</Mass>
			<StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.45</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<WorkSpeedGlobal>.05</WorkSpeedGlobal>
			<MoveSpeed>0.3</MoveSpeed>
		</equippedStatOffsets>
		<costList>
			<Cloth>80</Cloth>
		</costList>

		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>OnSkin</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/UtilityJumpsuit/Seg_WOTV_UtilityJumpsuit</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>

		<!-- <comps>
			<li Class="Core40k.CompProperties_Decorative">
