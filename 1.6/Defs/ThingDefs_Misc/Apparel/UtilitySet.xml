<Defs>
	<ThingDef Abstract="true" Name="Seg_WOTV_ClothingBase" ParentName="ArmorMachineableBase">
		<thingClass>Apparel</thingClass>
		<graphicData>
			<drawSize>1.0</drawSize>
		</graphicData>
		<thingCategories>
			<li>Apparel</li>
		</thingCategories>
		<tradeTags>
			<li>Seg_WOTV_Armor</li>
		</tradeTags>
		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<!--<tags></tags>-->
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
		</apparel>
		
		<recipeMaker>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Tailor</effectWorking>
			<soundWorking>Recipe_Tailor</soundWorking>
			<unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
			<recipeUsers Inherit="False">
				<li>Seg_ImperialCraftingTable</li>
			</recipeUsers>
		</recipeMaker>
	</ThingDef>

	<ApparelLayerDef>
		<defName>Seg_WOTV_Mask</defName>
		<label>Mask</label>
		<drawOrder>500</drawOrder>
	</ApparelLayerDef>

	<!-- Utility Mask -->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_UtilityMask</defName>
		<label>utility mask</label>
		<description>This mask provides glare and spark protection for manual labourers, such as those found in the enginarium or maintenance clans of a voidship's lower decks.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/UtilityMask/Seg_WOTV_UtilityMask</texPath>
			<!-- <drawOffset>(0,0,0.10)</drawOffset> -->
		</graphicData>

		<equippedStatOffsets>
			<WorkSpeedGlobal>.05</WorkSpeedGlobal>
			<SmeltingSpeed>.30</SmeltingSpeed>
			<ConstructionSpeed>.10</ConstructionSpeed>
			<ConstructSuccessChance>.10</ConstructSuccessChance>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>1.9</Mass>
			<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.65</ArmorRating_Heat>
			<Insulation_Cold>1.1</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Eyes</li>
				<li>Mouth</li>
				<li>Neck</li>
			</bodyPartGroups>
			<layers>
				<li>EyeCover</li>
			</layers>
			<drawData>
				<defaultData>
					<layer>69</layer>
				</defaultData>
			</drawData>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/UtilityMask/Seg_WOTV_UtilityMask</li>
			</wornGraphicPaths>
		</apparel>
		
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
		<!-- <comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Head</decorativeType>
			</li>
		</comps>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_ArmorDecoration</li>
				</tabDefs>
			</li>
		</modExtensions> -->
	</ThingDef>

	<!-- Utility Helmet -->
		<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_UtilityHelmet</defName>
		<label>utility helmet</label>
		<description>This rigid helmet is basic but effective protection for manual labourers, such as those found in the enginarium or maintenance clans of a voidship's lower decks.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/UtilityHelmet/Seg_WOTV_UtilityHelmet</texPath>
		</graphicData>
		<uiIconPath>Things/Apparel/UtilityHelmet/Seg_WOTV_UtilityHelmet</uiIconPath>

		<equippedStatOffsets>
			<WorkSpeedGlobal>.15</WorkSpeedGlobal>
			<ConstructionSpeed>.05</ConstructionSpeed>
			<ConstructSuccessChance>.05</ConstructSuccessChance>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>1.6</Mass>
			<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
			<ArmorRating_Heat>0.25</ArmorRating_Heat>
			<Insulation_Cold>5.4</Insulation_Cold>
			<Insulation_Heat>5</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>30</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
			<li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/UtilityHelmet/Seg_WOTV_UtilityHelmet</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
