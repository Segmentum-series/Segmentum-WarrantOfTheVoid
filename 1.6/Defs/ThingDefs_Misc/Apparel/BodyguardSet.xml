<Defs>

	<!-- Bodyguard Hat -->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_BodyguardHat</defName>
		<label>bodyguard hat</label>
		<description>Members of a Rogue Trader's retinue have more latitude in their personal dress than most armed servants of the Imperium, and what better way to express their individuality than to adopt some rakish headgear?</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/BodyguardHat/Seg_WOTV_BodyguardHat</texPath>
		</graphicData>

		<equippedStatOffsets>
			<SocialImpact>.10</SocialImpact>
			<MoveSpeed>0.1</MoveSpeed>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.05</SlaveSuppressionOffset>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<Insulation_Cold>14.4</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>10</Steel>
			<Cloth>50</Cloth>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
				<li>Seg_WOTV_BodyguardApparel</li>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/BodyguardHat/Seg_WOTV_BodyguardHat</li>
			</wornGraphicPaths>
		
			<renderSkipFlags>
					<li>Hair</li>
					<li>Beard</li>
					<li>Eyes</li>
			</renderSkipFlags>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>FlakArmor</li>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
		</recipeMaker>

		<!-- <comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Head</decorativeType>
			</li>
		</comps> -->

		<!-- <modExtensions>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_ArmorDecoration</li>
				</tabDefs>
			</li>
		</modExtensions> -->
	</ThingDef>


	<!--Bodyguard Uniform-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_BodyguardUniform</defName>
		<label>bodyguard uniform</label>
		<description>These clothes are a mix of standard fatigues and garments picked as much for style as for function. Such clothing is worn by mercenaries who like to make an impression, or the more flamboyant members of a Rogue Trader's retinue.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/BodyguardUniform/Seg_WOTV_BodyguardUniform</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>2.2</Mass>
			<StuffEffectMultiplierArmor>0.95</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.45</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>0.1</MoveSpeed>
			<IncomingDamageFactor>-0.1</IncomingDamageFactor>
		</equippedStatOffsets>

		<costList>
			<Cloth>70</Cloth>
		</costList>

		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>60</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>OnSkin</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/BodyguardUniform/Seg_WOTV_BodyguardUniform</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>FlakArmor</li>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
		</recipeMaker>

		<!-- <comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Body</decorativeType>
			</li>
		</comps>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_ArmorColoring</li>
					<li>BEWH_ArmorDecoration</li>
				</tabDefs>
			</li>
		</modExtensions> -->
	</ThingDef>

	<!--BodyguardJacket-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_BodyguardJacket</defName>
		<label>bodyguard jacket</label>
		<description>Besides being a good set of carapace armour to protect the wearer, the accompanying duster is irregularly reinforced with extra fabric and las-resistant weaves, adding an additional level of survivability in the likely event of a firefight.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/BodyguardJacket/Seg_WOTV_BodyguardJacket</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>32000</WorkToMake>
			<MaxHitPoints>300</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.90</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.85</ArmorRating_Blunt>
			<ArmorRating_Heat>0.70</ArmorRating_Heat>
			<Insulation_Cold>7</Insulation_Cold>
			<Insulation_Heat>10</Insulation_Heat>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.14</DecompressionResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.14</VacuumResistance>
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.1</MoveSpeed>
			<IncomingDamageFactor>-0.15</IncomingDamageFactor>
		</equippedStatOffsets>

		<costList>
			<Cloth>150</Cloth>
			<Steel>80</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
			<Seg_Ceramite>50</Seg_Ceramite>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>Middle</li>
				<li>Shell</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/BodyguardJacket/Seg_WOTV_BodyguardJacket</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>FlakArmor</li>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>9</Crafting>
			</skillRequirements>
		</recipeMaker>

