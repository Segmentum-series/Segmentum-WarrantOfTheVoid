<Defs>


	<!-- Trader Hat -->
		<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_TraderHat</defName>
		<label>trader hat</label>
		<description>No Lord Captain can expect to be taken seriously without a suitably imposing hat of office.</description>
        <graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/TraderHat/Seg_WOTV_TraderHat</texPath>
		</graphicData>
		<equippedStatOffsets>
			<SocialImpact>.20</SocialImpact>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<Insulation_Cold>14.4</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Cloth>80</Cloth>
			<Gold>20</Gold>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
            <li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/TraderHat/Seg_WOTV_TraderHat</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_TraderApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Head</decorativeType>
			</li>
		</comps>
		<modExtensions>
            <li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
                <tabDefs>
                    <li>BEWH_ArmorDecoration</li>
                </tabDefs>
            </li>
        </modExtensions>
	</ThingDef>


	<!--Trader Shirt-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_TraderShirt</defName>
		<label>trader shirt</label>
		<description>There is no uniform for the Rogue Traders of the Imperium, but many of them tend towards the flamboyant, lavish and almost piratical in their dress. This shirt is a typical example, embroidered and decorated to ensure everyone knows of the Trader's high status.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/TraderShirt/Seg_WOTV_TraderShirt</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<StuffEffectMultiplierArmor>0.95</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.45</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<SocialImpact>.10</SocialImpact>
			<MoveSpeed>-0.1</MoveSpeed>
            <IncomingDamageFactor>-0.1</IncomingDamageFactor>
		</equippedStatOffsets>
		<costList>
			<Cloth>170</Cloth>
			<Gold>20</Gold>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
			</bodyPartGroups>
			<layers>
				<li>OnSkin</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/TraderShirt/Seg_WOTV_TraderShirt</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_TraderApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Body</decorativeType>
			</li>
		</comps>
		<modExtensions>
            <li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
                <tabDefs>
                    <li>BEWH_ArmorColoring</li>
                    <li>BEWH_ArmorDecoration</li>
                </tabDefs>
            </li>
        </modExtensions>
	</ThingDef>
