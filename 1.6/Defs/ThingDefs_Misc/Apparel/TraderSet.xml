<Defs>


	<!-- Trader Hat -->
		<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_TraderHat</defName>
		<label>Trader Hat</label>
		<description>A stylish hat worn by traders for protection and fashion.</description>
        <graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/TraderHat/Seg_WOTV_TraderHat</texPath>
		</graphicData>
		<equippedStatOffsets>
			<WorkSpeedGlobal>.10</WorkSpeedGlobal>
			<SocialImpact>.15</SocialImpact>
			<MoveSpeed>0.1</MoveSpeed>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<Insulation_Cold>14.4</Insulation_Cold>
			<Insulation_Heat>20</Insulation_Heat>
		</statBases>

		<costList>
			<Steel>10</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
            <li>UpperHead</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/TraderHat/Seg_WOTV_TraderHat</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>ComplexClothing</li>
				<li>Seg_WOTV_TraderApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Head</decorativeType>
			</li>
		</comps>
		<modExtensions>
            <li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
                <tabDefs>
                    <li>BEWH_ArmorDecoration</li>
                </tabDefs>
            </li>
        </modExtensions>
	</ThingDef>


