    <!--Trader Armor-->
    <ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_TraderArmor</defName>
		<label>trader armour</label>
		<description>This armour may be ornamental, but it doesn't lack for protective qualities either. Rogue Traders tend to be aware of the dangers that come with their role, and when necessary they don flak or carapace armour quite happily - although they always ensure that it looks the part.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/TraderArmor/Seg_WOTV_TraderArmor</texPath>
		</graphicData>

		
		<statBases>
			<WorkToMake>45000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>2.2</Mass>
			<ArmorRating_Sharp>.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>1</ArmorRating_Blunt>
			<ArmorRating_Heat>0.85</ArmorRating_Heat>
			<Insulation_Cold>7</Insulation_Cold>
			<Insulation_Heat>10</Insulation_Heat>
			<DecompressionResistance MayRequire="kentington.saveourship2">0.14</DecompressionResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.14</VacuumResistance>
		</statBases>
		<equippedStatOffsets>
			<SocialImpact>.10</SocialImpact>
			<MoveSpeed>-0.1</MoveSpeed>
			<IncomingDamageFactor>-0.20</IncomingDamageFactor>
		</equippedStatOffsets>
		<costList>
			<Steel>70</Steel>
			<Gold>30</Gold>
