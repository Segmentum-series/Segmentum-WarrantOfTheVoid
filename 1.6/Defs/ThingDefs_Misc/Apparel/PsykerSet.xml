	<!--Psyker Robe-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_PsykerRobe</defName>
		<label>psyker robe</label>
		<description>Even the most highly ranked and esteemed psykers in the Imperium are often distrusted and feared. These lavish robes - covered in sigils, seals, and protective charms - at least reassure anyone nearby that this psyker has been processed by the Black Ships and sanctioned by the Emperor.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Apparel/PsykerRobe/Seg_WOTV_PsykerRobe</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>5.7</Mass>
			<StuffEffectMultiplierArmor>0.45</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.45</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<PsychicSensitivityOffset>0.50</PsychicSensitivityOffset>
			<PsychicEntropyRecoveryRate MayRequire="Ludeon.RimWorld.Royalty">0.05</PsychicEntropyRecoveryRate>
		</equippedStatOffsets>

		<costList>
			<Cloth>150</Cloth>
			<Steel>15</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
				<li>Seg_WOTV_PsykerApparel</li>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>Middle</li>
				<li>Shell</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/PsykerRobe/Seg_WOTV_PsykerRobe</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
		</recipeMaker>
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Body</decorativeType>
			</li>
		</comps>
		<thingCategories Inherit="False">
			<li>Seg_WOTV_PsykerApparel</li>
		</thingCategories>
	</ThingDef>
</Defs>