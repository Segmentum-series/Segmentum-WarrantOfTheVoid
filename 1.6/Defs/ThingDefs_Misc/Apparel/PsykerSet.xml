<Defs>

	<!-- Psyker Hood -->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_PsykerHood</defName>
		<label>psyker hood</label>
		<description>Psykers are feared and hated by the people of the galaxy even though the Imperium's transportation and communication infrastructure would collapse overnight without them. This hood serves to hide some of the psyker collar from sight, making people a bit more comfortable when dealing with these 'witches', sanctioned though they may be.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<!-- <shaderType>Cutout</shaderType> -->
			<texPath>Things/Apparel/PsykerHood/Seg_WOTV_PsykerHood</texPath>
			<!-- <drawOffset>(0,0,0.10)</drawOffset> -->
		</graphicData>

		<equippedStatOffsets>
			<PsychicSensitivityOffset>0.25</PsychicSensitivityOffset>
			<PsychicEntropyGain MayRequire="Ludeon.RimWorld.Royalty">-0.50</PsychicEntropyGain>
			<PsychicEntropyRecoveryRate MayRequire="Ludeon.RimWorld.Royalty">0.15</PsychicEntropyRecoveryRate>
		</equippedStatOffsets>
		<statBases>
			<WorkToMake>14000</WorkToMake>
			<MaxHitPoints>350</MaxHitPoints>
			<Mass>3.5</Mass>
			<ArmorRating_Sharp>0.65</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.65</ArmorRating_Blunt>
			<ArmorRating_Heat>0.75</ArmorRating_Heat>
			<Insulation_Cold>4</Insulation_Cold>
			<Insulation_Heat>7</Insulation_Heat>
		</statBases>

		<costList>
			<Cloth>20</Cloth>
			<Steel>25</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
			<ComponentSpacer>1</ComponentSpacer>
		</costList>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>30</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags>
				<li>Seg_WOTV_PsykerApparel</li>
			</tags>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Eyes</li>
				<li>Mouth</li>
				<li>Neck</li>
			</bodyPartGroups>
			<layers>
				<li>Overhead</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/PsykerHood/Seg_WOTV_PsykerHood</li>
			</wornGraphicPaths>
			<renderSkipFlags>
					<li>Hair</li>
			</renderSkipFlags>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_SpecialistApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
		</recipeMaker>
		<thingCategories Inherit="False">
			<li>Seg_WOTV_PsykerApparel</li>
		</thingCategories>
	</ThingDef>

	<!-- Psyker Helm -->
		<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_PsykerHelm</defName>
		<label>psyker helm</label>
