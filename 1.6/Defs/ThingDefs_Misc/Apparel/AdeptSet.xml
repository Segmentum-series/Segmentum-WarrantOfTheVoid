<Defs>

	<!--Adept Coat-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_AdeptCoat</defName>
		<label>adept coat</label>
		<description>This functional uniform is characteristic of the civilian specialists of the Imperium of Man. While the Imperium's propaganda centres the role of its armed forces and holy servants - from the Space Marines to the Guard and the militant orders of the Sisters of Battle - without the functionaries and bureaucrats and clerks of the Adeptus Administratum, it would grind to a halt.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/AdeptCoat/Seg_WOTV_AdeptCoat</texPath>
		</graphicData>
		<statBases>
			<WorkToMake>24000</WorkToMake>
			<MaxHitPoints>175</MaxHitPoints>
			<Mass>5.1</Mass>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.35</ArmorRating_Blunt>
			<ArmorRating_Heat>0.65</ArmorRating_Heat>
			<Insulation_Cold>7</Insulation_Cold>
			<Insulation_Heat>10</Insulation_Heat>
		</statBases>

		<equippedStatOffsets>
			<SocialImpact>.05</SocialImpact>
			<WorkSpeedGlobal>.05</WorkSpeedGlobal>
		</equippedStatOffsets>
		<costList>
			<Steel>5</Steel>
			<Cloth>120</Cloth>
		</costList>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>Shell</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/AdeptCoat/Seg_WOTV_AdeptCoat</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Body</decorativeType>
			</li>
		</comps>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_ArmorColoring</li>
					<li>BEWH_ArmorDecoration</li>
				</tabDefs>
			</li>
		</modExtensions>
		<thingCategories>
			<li>Seg_WOTV_ArmorInquisitorial</li>
		</thingCategories>
	</ThingDef>

	<!--Adept Wrapping-->
	<ThingDef ParentName="Seg_WOTV_ClothingBase">
		<defName>Seg_WOTV_Apparel_AdeptWrapping</defName>
		<label>adept wrapping</label>
		<description>Many adepts will wear belts and pouches to carry scrolls, data-slates, and containers so that they can perform their duties more efficiently.</description>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
			<texPath>Things/Apparel/AdeptWrapping/Seg_WOTV_AdeptWrapping</texPath>
		</graphicData>

		<statBases>
			<WorkToMake>12000</WorkToMake>
			<MaxHitPoints>125</MaxHitPoints>
			<Mass>3.2</Mass>
			<StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.25</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.25</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<ResearchSpeed>.10</ResearchSpeed>
			<WorkSpeedGlobal>.05</WorkSpeedGlobal>
		</equippedStatOffsets>
		<costList>
			<Steel>20</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>

		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>

		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<layers>
				<li>Middle</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
			<wornGraphicPaths>
				<li>Things/Apparel/AdeptWrapping/Seg_WOTV_AdeptWrapping</li>
			</wornGraphicPaths>
		</apparel>
		<recipeMaker>
			<researchPrerequisites>
				<li>Seg_WOTV_BasicApparel</li>
			</researchPrerequisites>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<comps>
			<li Class="Core40k.CompProperties_Decorative">
				<decorativeType>Body</decorativeType>
			</li>
		</comps>
		<modExtensions>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_ArmorColoring</li>
					<li>BEWH_ArmorDecoration</li>
				</tabDefs>
			</li>
		</modExtensions>
		<thingCategories>
			<li>Seg_WOTV_ArmorInquisitorial</li>
		</thingCategories>
	</ThingDef>
	<!-- Backpack base -->
	<ThingDef Abstract="true" Name="Seg_WOTV_BackpackBase" ParentName="ArmorMachineableBase">
		<techLevel>Spacer</techLevel>
		<recipeMaker>
			<unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
			<recipeUsers Inherit="false">
				<li>Seg_ImperialCraftingTable</li>
			</recipeUsers>
		</recipeMaker>
		<thingCategories>
			<li>Seg_WOTV_ArmorInquisitorial</li>
		</thingCategories>
		<tradeTags>
			<li>Seg_WOTV_InquisitorialArmor</li>
		</tradeTags>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>BEWH_CutoutThreeColor</shaderType>
		</graphicData>
		<apparel>
			<useWornGraphicMask>true</useWornGraphicMask>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
			</bodyPartGroups>
			<layers>
				<li>Backpack</li>
			</layers>
			<drawData>
				<dataSouth>
					<layer>-10</layer>
				</dataSouth>
				<dataWest>
					<layer>80</layer>
				</dataWest>
				<dataEast>
					<layer>80</layer>
				</dataEast>
				<dataNorth>
					<layer>100</layer>
				</dataNorth>
			</drawData>
			<careIfWornByCorpse>false</careIfWornByCorpse>
			<careIfDamaged>false</careIfDamaged>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
		</apparel>
		<modExtensions>
			<li Class="VEF.Apparels.ApparelExtension">
				<isUnifiedApparel>true</isUnifiedApparel>
				<hideHead>false</hideHead>
			</li>
		</modExtensions>
	</ThingDef>

	<!-- Adept backpack -->
	<ThingDef ParentName="Seg_WOTV_BackpackBase">
		<defName>Seg_WOTV_Apparel_AdeptPack</defName>
		<label>adept pack</label>
		<description>The Imperium runs on parchment, ink, and candle tallow as much as it does on promethium and fyceline, and carrying an auto-quill, data-slate and spare scrolls can help an adept in the fulfillment of their responsibilities.</description> 
		<graphicData>
			<texPath>Things/Apparel/AdeptPack/Seg_WOTV_AdeptPack</texPath>
		</graphicData>
		<recipeMaker>
			<researchPrerequisite>Seg_WOTV_BasicApparel</researchPrerequisite>
		</recipeMaker>
		<costList>
			<Steel>20</Steel>
			<ComponentIndustrial>2</ComponentIndustrial>
			<Cloth>60</Cloth>
			<WoodLog>30</WoodLog>
		
		</costList>
		<statBases>
			<WorkToMake>8000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>3.6</Mass>
			<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.30</ArmorRating_Blunt>
			<ArmorRating_Heat>0.01</ArmorRating_Heat> 
		</statBases>
		<equippedStatOffsets>
			<MoveSpeed>-0.15</MoveSpeed>
			<CarryingCapacity>15</CarryingCapacity>
			<SocialImpact>0.10</SocialImpact>
			<ResearchSpeed>0.35</ResearchSpeed>
            <ReadingSpeed>0.50</ReadingSpeed>
			<WorkSpeedGlobal>-0.10</WorkSpeedGlobal>
		</equippedStatOffsets>
		
		<apparel>
			<wornGraphicPath>Things/Apparel/AdeptPack/Seg_WOTV_AdeptPack</wornGraphicPath>
			<defaultOutfitTags>
				<li>Worker</li>
			</defaultOutfitTags>
		</apparel>
		<comps>
			<li Class="Core40k.CompProperties_MultiColor" MayRequire="phonicmas.rimdark.frameworkcore">
				<defaultPrimaryColor>(120,82,66)</defaultPrimaryColor>
				<defaultSecondaryColor>(255,255,255)</defaultSecondaryColor>
				<defaultTertiaryColor>(25,146,198)</defaultTertiaryColor>
				
			</li>
		</comps>
	</ThingDef>
</Defs>