<Defs>

	<!-- Laslock shot -->
	<ThingDef ParentName="BaseBullet">
		<defName>Seg_WOTV_LaslockShot</defName>
		<label>lasbolt</label>
		<description>A stabbing bolt of las energy.</description>
		<thingClass>taranchuk_lasers.LaserProjectile</thingClass>
		<category>Projectile</category>
		<drawOffscreen>true</drawOffscreen>
		<seeThroughFog>true</seeThroughFog>

		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Projectile/Seg_WOTV_Lasbolt</texPath>
			<shaderType>TransparentPostLight</shaderType>
			<drawSize>2</drawSize>
		</graphicData>

		<projectile>
			<damageDef>Seg_LasgunDamage</damageDef>
			<damageAmountBase>25</damageAmountBase>
			<armorPenetrationBase>0.40</armorPenetrationBase>
			<stoppingPower>3.5</stoppingPower>
			<speed>999</speed>
		</projectile>

		<modExtensions>
			<li Class="taranchuk_lasers.LaserProperties">
				<damageTickRate>20</damageTickRate>
				<lifetimeTicks>20</lifetimeTicks>
				<chainRange>0</chainRange>
				<maxChainTargets>0</maxChainTargets>
				<chainDelayTicks>100000</chainDelayTicks>
				<chainToAnything>false</chainToAnything>
				<maxBranches>0</maxBranches>
				<branchChance>0</branchChance>

				<beamWidth>0.7</beamWidth>
				<beamWidthDrawScale>1</beamWidthDrawScale>

				<sweepRatePerTick>0</sweepRatePerTick>
				<maxSweepAngle>0</maxSweepAngle>

				<damageThingsAcrossBeamLine>false</damageThingsAcrossBeamLine>
				<debugCells>false</debugCells>

				<textureScrollOffsetPerTick>(0, 0.1)</textureScrollOffsetPerTick>
				<lockOnTarget>false</lockOnTarget>
			</li>
		</modExtensions>
	</ThingDef>
	
