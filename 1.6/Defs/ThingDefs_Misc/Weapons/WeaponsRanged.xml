<Defs>
	<!-- Seg_WOTV_RangedWeaponBase -->
	<ThingDef ParentName="BaseHumanMakeableGun" Name="Seg_WOTV_RangedWeaponBase" Abstract="True">
		<label>Seg_WOTV_RangedWeaponBase</label>
		<description>Base definition for that Skitarii rifle thing i cant be assed to spell again.this should never show in game, if it does report to KitchenSink.</description>
		<techLevel>Spacer</techLevel>
		<recipeMaker>
			<researchPrerequisites Inherit="False">
				<li>Seg_MunitorumEquipment</li>
			</researchPrerequisites>
			<recipeUsers Inherit="False">
				<li>Seg_ImperialCraftingTable</li>
			</recipeUsers>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtWeaponGun</nameMaker>
				<descriptionMaker>ArtDescription_WeaponGun</descriptionMaker>
				<minQualityForArtistic>Good</minQualityForArtistic>
			</li>
			<!-- <li Class="Core40k.CompProperties_MultiColor">
				<colorMaskAmount>3</colorMaskAmount>
				<defaultPrimaryColor>(0.23,0.23,0.23)</defaultPrimaryColor>
				<defaultSecondaryColor>(0.38,0.38,0.38)</defaultSecondaryColor>
				<defaultTertiaryColor>(0.79,0.58,0.08)</defaultTertiaryColor>
			</li> -->
		</comps>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>4</cooldownTime>
			</li>
		</tools>
		<relicChance MayRequire="Ludeon.RimWorld.Ideology">0</relicChance>
		<weaponTags Inherit="False" />
		<tradeTags Inherit="False" />
	</ThingDef>

	<!-- Ryza-pattern Lasgun -->
	<ThingDef ParentName="Seg_WOTV_RangedWeaponBase">
		<defName>Seg_WOTV_Gun_RyzaLasgun</defName>
		<label>Lasgun (Ryza-pattern)</label>
		<description>Like all lasguns, the Ryza-pattern is not the most powerful firearm, but it is reliable, logistically simple, and can stop a charging greenskin at fifty paces with an accurate grouping of lasbolts. This is one of the oldest patterns of lasgun still in use in the Imperium, and is still frequently found in the hands of noble retinues or Inquisition warbands as well as seeing continuing use by forces supplied by the forge world of Ryza.</description>
		<graphicData>
			<texPath>Things/Weapon/Seg_WOTV_Ranged_Lasgun</texPath>
			<shaderType>Cutout</shaderType>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.2</drawSize>
		</graphicData>
		<recipeMaker>
			<researchPrerequisites Inherit="False">
				<li>Seg_MunitorumEquipment</li>
			</researchPrerequisites>
		</recipeMaker>
		<uiIconScale>1.4</uiIconScale>
		<statBases>
			<Mass>3.5</Mass>
			<EquipDelay>1.5</EquipDelay>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
			<AccuracyTouch>0.85</AccuracyTouch>
			<AccuracyShort>0.65</AccuracyShort>
			<AccuracyMedium>0.40</AccuracyMedium>
			<AccuracyLong>0.25</AccuracyLong>
			<WorkToMake>20000</WorkToMake>
			<MarketValue>1200</MarketValue>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Seg_WOTV_RyzaLasgunShot</defaultProjectile>
				<soundCast>Seg_WOTV_RyzaLasgunFire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<warmupTime>1</warmupTime>
				<range>26.9</range>
				<burstShotCount>4</burstShotCount>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<muzzleFlashScale>10</muzzleFlashScale>
			</li>
		</verbs>
		<costList>
			<Steel>70</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension">
				<weaponCarryDrawOffsets>
					<north>
						<angleOffset>-20</angleOffset>
						<drawOffset>(0.25, 0, 0)</drawOffset>
					</north>
					<east>
						<drawOffset>(0.3, 0, -0.15)</drawOffset>
					</east>
					<south>
						<angleOffset>-20</angleOffset>
						<drawOffset>(0.25, 0, -0.2)</drawOffset>
					</south>
					<west>
						<drawOffset>(-0.3, 0, -0.15)</drawOffset>
					</west>
				</weaponCarryDrawOffsets>
			</li>
		</modExtensions>
		<!-- Tags for trading and categorization for later-->
		<weaponTags>
			<li>Seg_WOTV_Las</li>
		</weaponTags>
		<tradeTags>
			<li>Seg_WOTV_Las</li>
		</tradeTags>
	</ThingDef>

	<!-- Las-lock -->
	<ThingDef ParentName="Seg_WOTV_RangedWeaponBase">
		<defName>Seg_WOTV_Gun_LasLock</defName>
		<label>Las-lock</label>
		<description>The las-lock is an archaic type of las weapon that focuses its energy into powerful single shots with a significant recharge time rather than being capable of bursts or sustained fire. Las-locks are often handbuilt outside of manufactoria and used by militias, scavengers, and heretics, although some better-quality examples following established patterns are still in use in Militarum regiments or for the armsmen of Rogue Trader houses.</description>
		<recipeMaker>
			<researchPrerequisites Inherit="False">
				<li>Seg_MunitorumEquipment</li>
			</researchPrerequisites>
		</recipeMaker>
		<graphicData>
			<texPath>Things/Weapon/Seg_WOTV_Ranged_Laslock</texPath>
			<shaderType>Cutout</shaderType>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<uiIconScale>1.3</uiIconScale>
		<statBases>
			<Mass>5</Mass>
			<EquipDelay>1.2</EquipDelay>
			<RangedWeapon_Cooldown>5</RangedWeapon_Cooldown>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.90</AccuracyMedium>
			<AccuracyLong>0.80</AccuracyLong>
			<WorkToMake>6000</WorkToMake>
			<MarketValue>800</MarketValue>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Seg_WOTV_LaslockShot</defaultProjectile>
				<soundCast>ChargeLance_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<warmupTime>3</warmupTime>
				<range>36.9</range>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>30</ticksBetweenBurstShots>
				<muzzleFlashScale>10</muzzleFlashScale>
			</li>
		</verbs>
		<costList>
			<Steel>50</Steel>
			<WoodLog>10</WoodLog>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<!-- Tags for trading and categorization for later-->
		<weaponTags>
			<li>Seg_WOTV_Las</li>
		</weaponTags>
		<tradeTags>
			<li>Seg_WOTV_Las</li>
		</tradeTags>
	</ThingDef>

	<!--Stub revolver-->
	<ThingDef ParentName="BaseHumanMakeableGun" Name="Gun_Revolver">
		<defName>Seg_WOTV_StubRevolver</defName>
		<label>stub revolver</label>
		<description>This short-barrelled large-calibre revolver fires solid bullets from a rotating chamber. It is a weapon of an ancient type, possibly dating back as far as late M2, and is rarely used by the Militarum except as an unofficial sidearm. It is most often found in the hands of enforcers and hive gangers, or perhaps noble lifewards who fancy themselves as dashing gunslingers.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Weapon/Seg_WOTV_Ranged_Revolver</texPath>
			<shaderType>Cutout</shaderType>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<uiIconScale>1.8</uiIconScale>
		<soundInteract>Interact_Revolver</soundInteract>
		<statBases>
			<WorkToMake>6000</WorkToMake>
			<Mass>1.2</Mass>
			<AccuracyTouch>0.85</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.40</AccuracyMedium>
			<AccuracyLong>0.30</AccuracyLong>
			<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>Seg_WOTV_BasicWeapons</li>
		</weaponTags>
		<weaponClasses>
			<li>RangedLight</li>
		</weaponClasses>
		<costList>
			<Steel>40</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
		</costList>
		<recipeMaker>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
			<researchPrerequisites Inherit="False">
				<li>Seg_WOTV_AdvancedEquipment</li>
			</researchPrerequisites>
			<displayPriority>400</displayPriority>
		</recipeMaker>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Seg_WOTV_StubRevolverBullet</defaultProjectile>
				<warmupTime>0.2</warmupTime>
				<range>21.9</range>
				<soundCast>Shot_Revolver</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>10</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>grip</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>13</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
  </ThingDef>

</Defs>
