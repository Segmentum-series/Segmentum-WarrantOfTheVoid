<Defs>

	<!-- Rogue Trader -->
	<PawnKindDef ParentName="BasePlayerPawnKind">
		<defName>Seg_WOTV_ScenarioPawnKind_RogueTrader</defName>
		<label>Rogue Trader</label>
		<defaultFactionType>Seg_WOTV_PlayerRT</defaultFactionType>
		<race>Human</race>
		<chemicalAddictionChance>0</chemicalAddictionChance>
		<apparelIgnoreSeasons>true</apparelIgnoreSeasons>
		<apparelTags Inherit="False">
			<!-- <li>?</li> -->
		</apparelTags>
		<apparelRequired Inherit="False">
			<li>Seg_WOTV_Apparel_TraderHat</li>
			<li>Seg_WOTV_Apparel_TraderCoat</li>
			<li>Seg_WOTV_Apparel_TraderShirt</li>
			<li>Seg_WOTV_Apparel_TraderPants</li>
		</apparelRequired>
		<ignoreIdeoApparelColors>true</ignoreIdeoApparelColors>
		<initialWillRange>0~0</initialWillRange>
		<apparelMoney>0~0</apparelMoney>
		<initialResistanceRange>13~21</initialResistanceRange>
		<humanPregnancyChance>0</humanPregnancyChance>
		<backstoryFiltersOverride>
			<li>
			<categoriesChildhood>
				<li>SegWOTV_NobleBackstories</li>
			</categoriesChildhood>
			<categoriesAdulthood>
				<li>SegWOTV_NobleBackstories</li>
			</categoriesAdulthood>
			</li>
		</backstoryFiltersOverride>
	</PawnKindDef>

